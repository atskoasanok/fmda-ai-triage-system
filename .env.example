LLM_PROVIDER=openai

API_KEY=your_api_key_here

BASE_URL=https://api.openai.com/v1

MODEL_NAME=gpt-4o-mini

USE_MOCK=true/false

TEMPERATURE=0.3

# URL of the FastAPI backend. For local dev use http://127.0.0.1:8000;
# for Docker Compose set this to the backend service name, e.g. http://backend:8000
FMDA_BACKEND_URL=http://127.0.0.1:8000

# Origin of the Streamlit frontend, used by the backend CORS policy.
# For Docker Compose this is typically http://localhost:8501
FRONTEND_ORIGIN=http://localhost:8501
